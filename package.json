{
  "name": "mutual-aid",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@mutual-aid/web",
    "dev:studio": "turbo dev --filter=@mutual-aid/studio",
    "build:web": "turbo build --filter=@mutual-aid/web",
    "build:studio": "turbo build --filter=@mutual-aid/studio"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
